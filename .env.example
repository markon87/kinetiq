# Public upload constraints used by both client and API.
# Keep these values aligned with product requirements.
NEXT_PUBLIC_UPLOAD_MAX_SIZE_BYTES=8388608
NEXT_PUBLIC_UPLOAD_ACCEPTED_TYPES=image/png,image/jpeg,image/webp

# Supabase project configuration.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Backward-compatible fallback if your project still uses anon naming.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key for privileged operations in API routes.
SUPABASE_SERVICE_ROLE_KEY=

# Reserved for future real model integration.
# ANALYZER_API_KEY=
# ANALYZER_MODEL=
